# Browser-visible Vercel variables (safe to expose to users)
NEXT_PUBLIC_CONTACT_SERVER_URL=http://localhost:3002
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Server-only Vercel variables (never prefix these with NEXT_PUBLIC_)
RAG_API_URL=http://localhost:3001
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token
HUBSPOT_DEAL_PIPELINE_ID=default
HUBSPOT_DEAL_STAGE_ID=appointmentscheduled
HUBSPOT_TICKET_PIPELINE_ID=0
HUBSPOT_TICKET_STAGE_ID=1

# Optional bot protection (disabled unless explicitly true)
ENABLE_RATE_LIMITING=false
ENABLE_HONEYPOT=false
ENABLE_TIME_VALIDATION=false
ENABLE_PATTERN_DETECTION=false
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_HOUR=30
RATE_LIMIT_PER_DAY=100
RATE_LIMIT_COOLDOWN=30
MIN_SECONDS_BEFORE_SUBMIT=2
MIN_SECONDS_BETWEEN_MESSAGES=1
